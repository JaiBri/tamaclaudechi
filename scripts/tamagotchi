#!/bin/bash
# Tamagotchi state engine for Claude mascot — v3 stat redesign
# Usage: tamagotchi <command> [options]
#
# Commands:
#   update --event <type>   Update stats based on event, output mood JSON
#   status [--json]         Print current stats (human or JSON)
#   reset                   Reset to defaults
#   pet                     Pet the mascot (+5 bond)
#   rename <name>           Give the mascot a name
#   usage                   Show system resource usage with personality

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- Source libraries ---
source "$SCRIPT_DIR/lib/math-helpers.sh"
source "$SCRIPT_DIR/lib/time-helpers.sh"
source "$SCRIPT_DIR/lib/json-helpers.sh"

# --- Source core modules ---
source "$SCRIPT_DIR/core/state.sh"
source "$SCRIPT_DIR/core/decay.sh"
source "$SCRIPT_DIR/core/events.sh"
source "$SCRIPT_DIR/core/serenity.sh"
source "$SCRIPT_DIR/core/rest.sh"
source "$SCRIPT_DIR/core/mood.sh"
source "$SCRIPT_DIR/core/achievements.sh"
source "$SCRIPT_DIR/core/output.sh"

# --- Source commands ---
source "$SCRIPT_DIR/commands/update.sh"
source "$SCRIPT_DIR/commands/status.sh"
source "$SCRIPT_DIR/commands/reset.sh"
source "$SCRIPT_DIR/commands/pet.sh"
source "$SCRIPT_DIR/commands/rename.sh"
source "$SCRIPT_DIR/commands/config.sh"
source "$SCRIPT_DIR/commands/usage.sh"
source "$SCRIPT_DIR/commands/diagnose.sh"

# --- Main ---
CMD="${1:-status}"
shift || true

case "$CMD" in
  update)
    EVENT="prompt"
    while [ $# -gt 0 ]; do
      case "$1" in
        --event) EVENT="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    cmd_update "$EVENT"
    ;;
  status)
    cmd_status "$@"
    ;;
  reset)
    cmd_reset
    ;;
  pet)
    cmd_pet
    ;;
  rename)
    cmd_rename "${1:-}"
    ;;
  config)
    cmd_config "$@"
    ;;
  usage)
    cmd_usage
    ;;
  diagnose)
    cmd_diagnose "$@"
    ;;
  *)
    echo "Usage: tamagotchi {update|status|reset|pet|rename|config|usage|diagnose} [options]"
    echo ""
    echo "Commands:"
    echo "  update --event <type>  Update stats (task_complete|prompt|code_change|test_run|lint_run|docs_change|refactor|...)"
    echo "  status [--json]        Show current stats (ASCII dashboard or JSON snapshot)"
    echo "  reset                  Reset to defaults"
    echo "  pet                    Pet the mascot (+bond)"
    echo "  rename <name>          Give it a name"
    echo "  config get             Show config JSON"
    echo "  config repo-roots      List configured repo roots"
    echo "  config repo-roots --add <path>    Add a repo root"
    echo "  config repo-roots --remove <path> Remove a repo root"
    echo "  config repo-roots --scan          Scan roots for .claude/git status"
    echo "  usage                  Show system resource usage with personality"
    echo "  diagnose [subcmd]      Run diagnostics (logs, hooks, state, sources, all)"
    exit 1
    ;;
esac
