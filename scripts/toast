    60%  { transform: translateX(-50%) scaleX(1.3); opacity: 0.5; }
    100% { transform: translateX(-50%) scaleX(1); opacity: 1; }
  }
  @keyframes jiggle {
    0% { transform: rotate(0); }
    20% { transform: rotate(-5deg); }
