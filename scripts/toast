cat > "$SWIFT_SRC" << 'SWIFTEOF'
import Cocoa
import WebKit

class ToastWindowController: NSObject, WKNavigationDelegate {
    let window: NSWindow
    let webView: WKWebView
    var titleObservation: NSKeyValueObservation?
    var globalMonitor: Any?
    var localMonitor: Any?
    var lastHitTestTime: CFAbsoluteTime = 0
    let hitTestThrottle: CFAbsoluteTime = 0.05  // 50ms

    override init() {
        let screenFrame = NSScreen.main?.visibleFrame ?? NSRect(x: 0, y: 0, width: 1440, height: 900)
        let winWidth: CGFloat = 420
        let winHeight: CGFloat = 160
        let x = screenFrame.maxX - winWidth - 20
        let y = screenFrame.maxY - winHeight - 20

        let rect = NSRect(x: x, y: y, width: winWidth, height: winHeight)

        window = NSWindow(
            contentRect: rect,
            styleMask: .borderless,
            backing: .buffered,
            defer: false
        )
        window.isOpaque = false
        window.backgroundColor = .clear
        window.level = .floating
        window.hasShadow = false
        window.collectionBehavior = [.canJoinAllSpaces, .stationary]
        window.ignoresMouseEvents = true  // Click-through by default

        let config = WKWebViewConfiguration()
        config.preferences.setValue(true, forKey: "allowFileAccessFromFileURLs")
        webView = WKWebView(frame: rect, configuration: config)
        webView.setValue(false, forKey: "drawsBackground")

        super.init()
        webView.navigationDelegate = self

        window.contentView = webView

        titleObservation = webView.observe(\.title, options: [.new]) { _, change in
            guard let newTitle = change.newValue as? String else { return }
            if newTitle == "ACTIVATE" {
                let task = Process()
                task.executableURL = URL(fileURLWithPath: "/bin/bash")
                task.arguments = ["/tmp/toast-activate.sh"]
                try? task.run()
                task.waitUntilExit()
                NSApplication.shared.terminate(nil)
            } else if newTitle == "CLOSE" {
                NSApplication.shared.terminate(nil)
            }
        }

        setupMouseMonitors()
    }

    func setupMouseMonitors() {
        // Global monitor: fires when window ignoresMouseEvents = true
        // Detects cursor entering interactive regions
        globalMonitor = NSEvent.addGlobalMonitorForEvents(matching: [.mouseMoved, .leftMouseDown]) { [weak self] _ in
            self?.performHitTest()
        }

        // Local monitor: fires when window accepts events
        // Detects cursor leaving interactive regions
        localMonitor = NSEvent.addLocalMonitorForEvents(matching: [.mouseMoved, .leftMouseDown]) { [weak self] event in
            self?.performHitTest()
            return event
        }
    }

    func performHitTest() {
        let now = CFAbsoluteTimeGetCurrent()
        guard now - lastHitTestTime >= hitTestThrottle else { return }
        lastHitTestTime = now

        let mouseLocation = NSEvent.mouseLocation
        let windowFrame = window.frame

        // Check if cursor is within the window bounds
        guard windowFrame.contains(mouseLocation) else {
            if window.ignoresMouseEvents { return }  // Already ignoring
            window.ignoresMouseEvents = true
            return
        }

        // Convert screen coords to WebView CSS coords
        // macOS Y is bottom-up, HTML Y is top-down
        let localX = mouseLocation.x - windowFrame.origin.x
        let localY = windowFrame.height - (mouseLocation.y - windowFrame.origin.y)

        let js = "document.elementFromPoint(\(localX),\(localY))?.closest('.bubble,.mascot-wrap,.stats-hud') !== null"
        webView.evaluateJavaScript(js) { [weak self] result, _ in
            guard let self = self else { return }
            let isInteractive = result as? Bool ?? false
            DispatchQueue.main.async {
                self.window.ignoresMouseEvents = !isInteractive
            }
        }
    }

    func cleanup() {
        if let monitor = globalMonitor {
            NSEvent.removeMonitor(monitor)
            globalMonitor = nil
        }
        if let monitor = localMonitor {
            NSEvent.removeMonitor(monitor)
            localMonitor = nil
        }
    }

    func load(url: URL) {
        webView.load(URLRequest(url: url))
        window.orderFrontRegardless()
    }
}

let app = NSApplication.shared
app.setActivationPolicy(.accessory)

let controller = ToastWindowController()

let totalTimeoutMs = CommandLine.arguments.count > 1 ? CommandLine.arguments[1] : "6000"

controller.load(url: URL(fileURLWithPath: "/tmp/toast.html"))

let totalTimeout = (Double(totalTimeoutMs) ?? 6000) / 1000.0
DispatchQueue.main.asyncAfter(deadline: .now() + totalTimeout) {
    controller.cleanup()
    NSApplication.shared.terminate(nil)
}

app.run()
SWIFTEOF

  swiftc -o "$SWIFT_BIN" "$SWIFT_SRC" -framework Cocoa -framework WebKit 2>/dev/null
fi

# Build click-to-activate script (finds the exact window/tab via TTY)
TTY_PATH="${TTY:-}"
if [ -z "$TTY_PATH" ]; then
  TTY_RAW=$(ps -o tty= -p $PPID 2>/dev/null | tr -d ' ')
  [ -n "$TTY_RAW" ] && [ "$TTY_RAW" != "??" ] && TTY_PATH="/dev/$TTY_RAW"
fi

ACTIVATE_SCRIPT="/tmp/toast-activate.sh"
case "${TERM_PROGRAM:-}" in
  Apple_Terminal)
    cat > "$ACTIVATE_SCRIPT" << ACTEOF
osascript -e '
tell application "Terminal"
    activate
    repeat with w in windows
        repeat with t in tabs of w
            if tty of t is "$TTY_PATH" then
                set selected tab of w to t
                set index of w to 1
                return
            end if
        end repeat
    end repeat
end tell'
ACTEOF
    ;;
  iTerm.app)
    cat > "$ACTIVATE_SCRIPT" << ACTEOF
osascript -e '
tell application "iTerm2"
    activate
    repeat with w in windows
        repeat with t in tabs of w
            repeat with s in sessions of t
                if tty of s is "$TTY_PATH" then
                    select t
                    select s
                    set index of w to 1
                    return
                end if
            end repeat
        end repeat
    end repeat
end tell'
ACTEOF
    ;;
  ghostty)
    cat > "$ACTIVATE_SCRIPT" << 'ACTEOF'
open -a Ghostty
ACTEOF
    ;;
  vscode)
    cat > "$ACTIVATE_SCRIPT" << 'ACTEOF'
open -a "Visual Studio Code"
ACTEOF
    ;;
  *)
    cat > "$ACTIVATE_SCRIPT" << 'ACTEOF'
true
ACTEOF
    ;;
esac
chmod +x "$ACTIVATE_SCRIPT"

# --- Background processor loop ---
# Drains ALL queued files into a batch, launches mascot once per batch.
(
  while true; do
    FILES=($(ls -1 "$QUEUE_DIR" 2>/dev/null | sort))
    if [ ${#FILES[@]} -eq 0 ]; then
      rm -f "$PIDFILE"
      break
    fi

    # Brief pause to let rapid-fire toasts accumulate
    sleep 0.15
    FILES=($(ls -1 "$QUEUE_DIR" 2>/dev/null | sort))

    # Build batch JSON with voice file paths (JS plays audio directly)
    BATCH_JSON='{"messages":['
    TOTAL_MS=0
    FIRST=1
    LAST_VOICE=""
    COOLDOWN_FILE="/tmp/toast-voice-cooldown"

    for F in "${FILES[@]}"; do
      IFS='|' read -r QMODE QMSG QDUR QMOOD QACH < "$QUEUE_DIR/$F"
      rm -f "$QUEUE_DIR/$F"
      QMOOD="${QMOOD:-NEUTRAL}"
      QACH="${QACH:-}"

      # Scale voice line count by message word count
      WORD_COUNT=$(printf '%s' "$QMSG" | wc -w | tr -d ' ')
      if [ "$WORD_COUNT" -le 1 ]; then
        NUM_VOICES=1
      elif [ "$WORD_COUNT" -le 4 ]; then
        NUM_VOICES=2
      elif [ "$WORD_COUNT" -le 8 ]; then
        NUM_VOICES=3
      else
        NUM_VOICES=4
      fi

      # Pick voice lines with no consecutive duplicates + combination cooldown
      VOICE_DUR_MS=0
      VOICES_JSON=""
      SELECTED_VOICES=()
      if [ -d "$VOICES_DIR" ]; then
        ALL_LINES=("$VOICES_DIR"/v*.mp3)
        RETRIES=0
        MAX_RETRIES=10
        FIRST_ATTEMPT=""
        while true; do
          SELECTED_VOICES=()
          PICK_LAST="$LAST_VOICE"
          for (( i=0; i<NUM_VOICES; i++ )); do
            # Build candidate pool excluding last picked voice
            CANDIDATES=()
            for L in "${ALL_LINES[@]}"; do
              [ "$L" = "$PICK_LAST" ] && continue
              CANDIDATES+=("$L")
            done
            [ ${#CANDIDATES[@]} -eq 0 ] && CANDIDATES=("${ALL_LINES[@]}")
            PICK="${CANDIDATES[$((RANDOM % ${#CANDIDATES[@]}))]}"
            SELECTED_VOICES+=("$PICK")
            PICK_LAST="$PICK"
          done

          # Compute order-independent fingerprint
          FINGERPRINT=$(printf '%s\n' "${SELECTED_VOICES[@]}" | sort | tr '\n' '+' | sed 's/+$//')
          [ -z "$FIRST_ATTEMPT" ] && FIRST_ATTEMPT="$FINGERPRINT"

          # Check combination cooldown
          if [ -f "$COOLDOWN_FILE" ] && grep -qxF "$FINGERPRINT" "$COOLDOWN_FILE"; then
            RETRIES=$((RETRIES + 1))
            if [ $RETRIES -ge $MAX_RETRIES ]; then
              # Graceful degradation: accept first attempt
              # Re-pick using first attempt's fingerprint (already stored)
              break
            fi
            continue
          fi
          break
        done

        # Update LAST_VOICE for next message in batch
        LAST_VOICE="${SELECTED_VOICES[${#SELECTED_VOICES[@]}-1]}"

        # Update cooldown file (newest first, keep last 5)
        { echo "$FINGERPRINT"; [ -f "$COOLDOWN_FILE" ] && head -4 "$COOLDOWN_FILE"; } > "${COOLDOWN_FILE}.tmp"
        mv "${COOLDOWN_FILE}.tmp" "$COOLDOWN_FILE"

        # Sum durations of all selected files
        for V in "${SELECTED_VOICES[@]}"; do
          VDUR=$(afinfo "$V" 2>/dev/null | awk '/estimated duration/{printf "%d", $3 * 1000}')
          VOICE_DUR_MS=$(( VOICE_DUR_MS + ${VDUR:-800} ))
        done

        # Build JSON voices array
        VFIRST=1
        VOICES_JSON="\"voices\":["
        for V in "${SELECTED_VOICES[@]}"; do
          [ $VFIRST -eq 1 ] && VFIRST=0 || VOICES_JSON="$VOICES_JSON,"
          VOICES_JSON="$VOICES_JSON\"$V\""
        done
        VOICES_JSON="$VOICES_JSON],"
      fi

      # Escape message for JSON (handle quotes and backslashes)
      QMSG_ESC=$(printf '%s' "$QMSG" | sed 's/\\/\\\\/g; s/"/\\"/g')

      # Achievement JSON field
      ACH_JSON=""
      [ -n "$QACH" ] && ACH_JSON="\"achievement\":\"$QACH\","

      [ $FIRST -eq 1 ] && FIRST=0 || BATCH_JSON="$BATCH_JSON,"
      BATCH_JSON="$BATCH_JSON{\"msg\":\"$QMSG_ESC\",\"mode\":\"$QMODE\",\"mood\":\"$QMOOD\",${ACH_JSON}\"duration\":$QDUR,\"voiceDur\":$VOICE_DUR_MS,${VOICES_JSON}\"_\":0}"
      echo "[toast] mode=$QMODE mood=$QMOOD dur=${QDUR}ms voiceDur=${VOICE_DUR_MS}ms voices=${#SELECTED_VOICES[@]} msg=\"$QMSG\""

      # Per-message display time: voiceDur + 100 + duration + 1000 + 250 (bubbleOut)
      MSG_TIME=$(( VOICE_DUR_MS + 100 + QDUR + 1000 + 250 ))
      # Add inter-message gap (150ms) except after last
      TOTAL_MS=$(( TOTAL_MS + MSG_TIME + 150 ))
    done

    # Remove trailing gap, add entrance (700ms) and exit (1000ms) + generous margin
    # for audio playback latency (JS awaits real audio, can be slower than afinfo estimates)
    TOTAL_MS=$(( TOTAL_MS - 150 + 700 + 1000 + ${#FILES[@]} * 500 + 2000 ))

    BATCH_JSON="$BATCH_JSON]}"
    echo "$BATCH_JSON" > /tmp/toast-batch.json

    # Run Swift binary SYNCHRONOUSLY (JS handles audio playback)
    "$SWIFT_BIN" "$TOTAL_MS"
    sleep 0.3
  done
) &
echo $! > "$PIDFILE"
disown
