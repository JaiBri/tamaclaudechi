  @keyframes talk {
    from { transform: translateY(0); }
    to { transform: translateY(-2px); }
  }
  @keyframes spinOut {
    0%   { transform: translateY(0) scale(1) rotate(0deg); opacity: 1; }
    100% { transform: translateY(-60px) scale(0.3) rotate(720deg); opacity: 0; }
  }
  @keyframes shadowShrink {
    0%   { transform: translateX(-50%) scaleX(1); opacity: 1; }
    100% { transform: translateX(-50%) scaleX(0); opacity: 0; }
  }
</style>
</head>
<body>
<canvas id="confetti"></canvas>
<div class="container" id="toast">
  <div class="mascot-wrap">
    <img class="mascot" src="data:image/png;base64," />
    <div class="mascot-shadow"></div>
  </div>
  <div class="bubble">
    <span class="bubble-tail"></span>
    <div class="message" id="msg"></div>
  </div>
