#!/bin/bash
# Speech-bubble toast with Claude pixel mascot — queue-based
# Usage: toast [--mode permission|done] [--mood MOOD] [--achievement ACH] "message text" [duration_seconds]
#
# Enqueues the message and returns immediately.
# A single background processor plays toasts sequentially.

MODE="done"
MOOD="NEUTRAL"
ACHIEVEMENT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --mode) MODE="$2"; shift 2 ;;
    --mood) MOOD="$2"; shift 2 ;;
    --achievement) ACHIEVEMENT="$2"; shift 2 ;;
    *) break ;;
  esac
done

MSG="${1:-Hello}"
DURATION="${2:-3}"
DURATION_MS=$((DURATION * 1000))

# Resolve script directory for assets
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VOICES_DIR="$SCRIPT_DIR/../assets/voices"

# --- Queue mechanism ---
QUEUE_DIR="/tmp/toast-queue"
PIDFILE="/tmp/toast-processor.pid"
mkdir -p "$QUEUE_DIR"

# Enqueue: write MODE|MSG|DURATION_MS|MOOD|ACHIEVEMENT to a timestamped file
echo "${MODE}|${MSG}|${DURATION_MS}|${MOOD}|${ACHIEVEMENT}" > "$QUEUE_DIR/$(date +%s%N)-$$"

# Check if processor is already running
if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
  # Processor alive — it will pick up our queued file
  exit 0
fi

# Write HTML to temp file
cat > /tmp/toast.html << 'HTMLEOF'
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
