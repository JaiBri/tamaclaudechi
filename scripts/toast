<script>
  const mascot = document.querySelector('.mascot');
  const bubble = document.querySelector('.bubble');
  const msgEl = document.getElementById('msg');
  let currentMood = 'NEUTRAL';

  // --- Mood config ---
  const MOOD_CONFIG = {
    ECSTATIC:  { speed: 200, amplitude: 0.3, bob: 8, sway: 5, tilt: 0, filter: 'brightness(1.15) saturate(1.3)', color: '#4ade80', particles: 'doubleConfetti' },
    EXCITED:   { speed: 250, amplitude: 0.25, bob: 6, sway: 4, tilt: 0, filter: '', color: '#22d3ee', particles: 'sparkles' },
    HAPPY:     { speed: 350, amplitude: 0.2, bob: 5, sway: 3, tilt: 0, filter: '', color: '#4ade80', particles: 'confetti' },
    NEUTRAL:   { speed: 450, amplitude: 0.15, bob: 4, sway: 2, tilt: 0, filter: '', color: '#e2e8f0', particles: 'none' },
    TIRED:     { speed: 600, amplitude: 0.1, bob: 3, sway: 2, tilt: 3, filter: 'brightness(0.85)', color: '#94a3b8', particles: 'yawn' },
    SLEEPY:    { speed: 800, amplitude: 0.08, bob: 2, sway: 1.5, tilt: 8, filter: 'brightness(0.7) saturate(0.5)', color: '#64748b', particles: 'zzz' },
    SLEEPING:  { speed: 1000, amplitude: 0.05, bob: 1, sway: 0.5, tilt: 12, filter: 'brightness(0.5) saturate(0.3)', color: '#475569', particles: 'zzz' },
    HUNGRY:    { speed: 350, amplitude: 0.2, bob: 5, sway: 3, tilt: 0, filter: '', color: '#fb923c', particles: 'wobble' },
    STARVING:  { speed: 200, amplitude: 0.3, bob: 6, sway: 5, tilt: 0, filter: 'hue-rotate(-20deg) saturate(1.5)', color: '#ef4444', particles: 'exclaim' },
    SAD:       { speed: 550, amplitude: 0.12, bob: 3, sway: 2, tilt: 2, filter: 'saturate(0.6) brightness(0.9)', color: '#818cf8', particles: 'rain' },
    LONELY:    { speed: 700, amplitude: 0.08, bob: 2, sway: 1.5, tilt: 3, filter: 'saturate(0.4) brightness(0.8)', color: '#a78bfa', particles: 'tear' },
  };

  function getMoodConfig() { return MOOD_CONFIG[currentMood] || MOOD_CONFIG.NEUTRAL; }

  // --- Helpers ---
  function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

  // --- Web Audio API analyser for real volume ---
  let audioCtx, analyser, freqData;
  try {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 256;
    analyser.smoothingTimeConstant = 0.6;
    freqData = new Uint8Array(analyser.frequencyBinCount);
    analyser.connect(audioCtx.destination);
  } catch(e) {}

  function getVolume() {
    if (!analyser) return 0;
    analyser.getByteFrequencyData(freqData);
    let sum = 0;
    for (let i = 0; i < freqData.length; i++) sum += freqData[i];
    return sum / (freqData.length * 255); // 0–1
  }

  // Play a single audio file, routed through analyser
  function playAudioFile(path) {
    return new Promise(resolve => {
      const audio = new Audio('file://' + path);
      audio.volume = 0.15;
      if (audioCtx) {
        try {
          const src = audioCtx.createMediaElementSource(audio);
          src.connect(analyser);
        } catch(e) {}
      }
      audio.onended = resolve;
      audio.onerror = resolve;
      audio.play().catch(resolve);
    });
  }

  // Play all voice lines for a message, return total duration in ms
  async function playVoiceLines(m) {
    const voices = m.voices || [];
    if (voices.length === 0) return 0;
    if (audioCtx && audioCtx.state === 'suspended') await audioCtx.resume();
    const t0 = performance.now();
    for (const v of voices) {
      await playAudioFile(v);
    }
    return performance.now() - t0;
  }

  // --- Persistent breathing loop (mood-parameterized) ---
  let breathingActive = false;
  function startBreathing() {
    breathingActive = true;
    // Apply mood CSS filter
    const mc = getMoodConfig();
    mascot.style.filter = mc.filter || '';
    function tick() {
      if (!breathingActive) return;
      if (voiceActive) { requestAnimationFrame(tick); return; }
      const mc = getMoodConfig();
      const now = performance.now();
      const breathe = Math.sin(now / mc.speed) * mc.amplitude;
      const squash = -Math.sin(now / mc.speed) * (mc.amplitude * 0.35);
      const bob = Math.sin(now / mc.speed) * mc.bob;
      const sway = Math.sin(now / (mc.speed * 1.4)) * mc.sway;
      const tilt = mc.tilt;
      // Hungry: occasional rumble interrupt
      let rumble = 0;
      if (currentMood === 'HUNGRY' || currentMood === 'STARVING') {
        rumble = Math.sin(now / 40) * (Math.sin(now / 800) > 0.7 ? 3 : 0);
      }
      mascot.style.transform = `translateY(${bob}px) translateX(${rumble}px) scaleX(${1 + squash}) scaleY(${1 + breathe}) rotate(${sway + tilt}deg)`;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  function stopBreathing() { breathingActive = false; }

  // Audio-reactive animation — jumpy, stretchy, alive
  let voiceActive = false;
  let voiceStartTime = 0;
  let voiceEstDur = 3000;
  function startVoiceReactivity(estDur) {
    voiceActive = true;
    voiceStartTime = performance.now();
    voiceEstDur = estDur || 3000;
    function tick() {
      if (!voiceActive) return;
      const elapsed = performance.now() - voiceStartTime;

      // Try real analyser volume, fall back to simulated
      let vol = getVolume();
      if (vol < 0.01) {
        const t = Math.min(elapsed / voiceEstDur, 1);
        const envelope = Math.sin(t * Math.PI);
        const pulse = Math.sin(elapsed / 60) * 0.6 + Math.sin(elapsed / 90) * 0.4;
        vol = 0.35 + envelope * 0.65 + pulse * 0.35;
        vol = Math.max(0, Math.min(1, vol));
      }

      const now = performance.now();
      // Big stretchy squash & stretch
      const stretchY = 1 + vol * 0.35;           // up to 1.35x tall
      const squashX = 1 - vol * 0.12;             // squash wide when stretching tall
      // Jumpy bounce
      const bounceY = -Math.abs(Math.sin(now / 45)) * vol * 8;  // up to 8px hop
      // Snappy rotation jiggle
      const jiggleRot = Math.sin(now / 55) * vol * 6;  // up to ±6deg

      mascot.style.transform = `translateY(${bounceY}px) scaleX(${squashX}) scaleY(${stretchY}) rotate(${jiggleRot}deg)`;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  // --- Confetti system with ribbons, circles, stars ---
  function createParticle(x, y) {
    const colors = ['#4ade80', '#22d3ee', '#a78bfa', '#fb923c', '#f472b6', '#facc15'];
    const shapes = ['ribbon', 'circle', 'star', 'square'];
    return {
      x, y,
      vx: (Math.random() - 0.5) * 10,
      vy: -Math.random() * 7 - 3,
      size: Math.random() * 5 + 2,
      color: colors[Math.floor(Math.random() * colors.length)],
      shape: shapes[Math.floor(Math.random() * shapes.length)],
      rotation: Math.random() * 360,
      rotSpeed: (Math.random() - 0.5) * 12,
      wobble: Math.random() * Math.PI * 2,
      wobbleSpeed: 0.03 + Math.random() * 0.04,
      life: 1,
      drag: 0.98 + Math.random() * 0.015,
    };
  }

  function drawParticle(ctx, p) {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rotation * Math.PI / 180);
    ctx.globalAlpha = Math.max(0, p.life);
    ctx.fillStyle = p.color;

    switch(p.shape) {
      case 'ribbon':
        ctx.fillRect(-p.size * 1.5, -p.size * 0.3, p.size * 3, p.size * 0.6);
        break;
      case 'circle':
        ctx.beginPath();
        ctx.arc(0, 0, p.size * 0.6, 0, Math.PI * 2);
        ctx.fill();
        break;
      case 'star':
        ctx.beginPath();
        for (let i = 0; i < 5; i++) {
          const a = (i * 4 * Math.PI / 5) - Math.PI / 2;
          const r = i === 0 ? p.size : p.size;
          ctx[i === 0 ? 'moveTo' : 'lineTo'](Math.cos(a) * r, Math.sin(a) * r);
          const b = a + 2 * Math.PI / 5;
          ctx.lineTo(Math.cos(b) * r * 0.4, Math.sin(b) * r * 0.4);
        }
        ctx.closePath();
        ctx.fill();
        break;
      default:
        ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
    }
    ctx.restore();
  }

  let confettiParticles = [];
  let confettiRunning = false;
  let vacuumMode = false;
  let vacuumTarget = { x: 0, y: 0 };

  function startConfetti() {
    const canvas = document.getElementById('confetti');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    canvas.width = window.innerWidth * dpr;
    canvas.height = window.innerHeight * dpr;
    ctx.scale(dpr, dpr);

    const ox = window.innerWidth - 40;
    const oy = window.innerHeight - 50;

    for (let i = 0; i < 40; i++) {
      confettiParticles.push(createParticle(
        ox + Math.random() * 30 - 15,
        oy + Math.random() * 10 - 5
      ));
    }
    setTimeout(() => {
      for (let i = 0; i < 25; i++) {
        confettiParticles.push(createParticle(
          ox + Math.random() * 30 - 15,
          oy + Math.random() * 10 - 5
        ));
      }
    }, 200);

    if (confettiRunning) return;
    confettiRunning = true;

    function animate() {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      let alive = false;
      for (const p of confettiParticles) {
        if (p.life <= 0) continue;
        alive = true;

        if (vacuumMode) {
          const dx = vacuumTarget.x - p.x;
          const dy = vacuumTarget.y - p.y;
          p.vx += dx * 0.06;
          p.vy += dy * 0.06;
          p.vx *= 0.92;
          p.vy *= 0.92;
          p.life -= 0.03;
        } else {
          p.wobble += p.wobbleSpeed;
          p.vx += Math.sin(p.wobble) * 0.3;
          p.vx *= p.drag;
          p.vy += 0.12;
          p.life -= 0.008;
        }

        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.rotSpeed;

        drawParticle(ctx, p);
      }
      if (alive) requestAnimationFrame(animate);
      else confettiRunning = false;
    }
    requestAnimationFrame(animate);
  }

  function startVacuum() {
    const rect = mascot.getBoundingClientRect();
    vacuumTarget = { x: rect.left + rect.width / 2, y: rect.top + rect.height / 2 };
    vacuumMode = true;
    for (const p of confettiParticles) {
      if (p.life > 0) p.life = Math.max(p.life, 0.5);
    }
  }

  // --- Orbiting question marks (permission mode) ---
  function spawnOrbitingMarks() {
    const mascotRect = mascot.getBoundingClientRect();
    const cx = mascotRect.left + mascotRect.width / 2;
    const cy = mascotRect.top + mascotRect.height / 2;
    const radius = 35;
    const count = 5;
    let spawned = 0;

    const iv = setInterval(() => {
      if (spawned >= count) { clearInterval(iv); return; }
      const q = document.createElement('div');
      q.className = 'orbit-q';
      q.textContent = '?';
      q.style.fontSize = (14 + Math.random() * 10) + 'px';
      document.body.appendChild(q);

      const baseAngle = (spawned / count) * Math.PI * 2 + Math.random() * 0.5;
      const startTime = performance.now();
      const orbitDur = 2500;

      function animateOrbit() {
        const elapsed = performance.now() - startTime;
        const t = elapsed / orbitDur;
        if (t > 1) { q.remove(); return; }
        const angle = baseAngle + t * Math.PI * 1.5;
        const r = radius * (1 - t * 0.3);
        const floatY = -t * 40;
        q.style.left = (cx + Math.cos(angle) * r - 8) + 'px';
        q.style.top = (cy + Math.sin(angle) * r + floatY - 8) + 'px';
        requestAnimationFrame(animateOrbit);
      }
      requestAnimationFrame(animateOrbit);
      spawned++;
    }, 400);
  }

  // --- Mood particle systems ---
  let moodParticleInterval = null;
  function startMoodParticles() {
    stopMoodParticles();
    const mc = getMoodConfig();
    if (mc.particles === 'none' || mc.particles === 'confetti' || mc.particles === 'doubleConfetti') return;

    const mascotRect = mascot.getBoundingClientRect();
    const cx = mascotRect.left + mascotRect.width / 2;
    const cy = mascotRect.top + mascotRect.height / 2;

    function spawn() {
      const el = document.createElement('div');
      el.className = 'mood-particle';
      switch (mc.particles) {
        case 'zzz':
          el.classList.add('zzz');
          el.textContent = 'Z';
          el.style.left = (cx + (Math.random() - 0.5) * 20) + 'px';
          el.style.top = (cy - 10) + 'px';
          el.style.fontSize = (14 + Math.random() * 10) + 'px';
          break;
        case 'rain':
          el.classList.add('rain');
          el.style.left = (cx + (Math.random() - 0.5) * 50) + 'px';
          el.style.top = (cy - 5) + 'px';
          break;
        case 'tear':
          el.classList.add('tear');
          el.textContent = '💧';
          el.style.left = (cx + (Math.random() > 0.5 ? 8 : -12)) + 'px';
          el.style.top = (cy + 5) + 'px';
          break;
        case 'sparkles':
          el.classList.add('sparkle');
          el.textContent = '✦';
          el.style.left = (cx + (Math.random() - 0.5) * 60) + 'px';
          el.style.top = (cy + (Math.random() - 0.5) * 40) + 'px';
          break;
        case 'exclaim':
          el.classList.add('exclaim');
          el.textContent = '!';
          // Orbit around mascot
          const angle = Math.random() * Math.PI * 2;
          const r = 30 + Math.random() * 15;
          el.style.left = (cx + Math.cos(angle) * r) + 'px';
          el.style.top = (cy + Math.sin(angle) * r) + 'px';
          break;
        case 'yawn':
          // Subtle bob effect (handled in breathing), just occasional text
          if (Math.random() > 0.3) return;
          el.classList.add('zzz');
          el.textContent = '~';
          el.style.left = (cx + 15) + 'px';
          el.style.top = (cy - 5) + 'px';
          el.style.color = '#94a3b8';
          break;
        case 'wobble':
          // Stomach wobble handled in breathing rumble
          return;
      }
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 3000);
    }

    const interval = mc.particles === 'zzz' ? 1200 : mc.particles === 'rain' ? 200 : mc.particles === 'tear' ? 3000 : 800;
    spawn();
    moodParticleInterval = setInterval(spawn, interval);
  }
  function stopMoodParticles() {
    if (moodParticleInterval) { clearInterval(moodParticleInterval); moodParticleInterval = null; }
  }

  // --- Achievement celebration effects ---
  function celebrateAchievement(name) {
    const mascotRect = mascot.getBoundingClientRect();
    const cx = mascotRect.left + mascotRect.width / 2;
    const cy = mascotRect.top;
    switch (name) {
      case 'firstFriend':
        for (let i = 0; i < 8; i++) {
          setTimeout(() => {
            const el = document.createElement('div');
            el.className = 'mood-particle heart';
            el.textContent = '❤️';
            el.style.left = (cx + (Math.random() - 0.5) * 60) + 'px';
            el.style.top = (cy + (Math.random() - 0.5) * 30) + 'px';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2000);
          }, i * 150);
        }
        break;
      case 'nightOwl':
        for (let i = 0; i < 5; i++) {
          setTimeout(() => {
            const el = document.createElement('div');
            el.className = 'mood-particle sparkle';
            el.textContent = '🦉';
            el.style.fontSize = '20px';
            el.style.left = (cx + (Math.random() - 0.5) * 50) + 'px';
            el.style.top = (cy + (Math.random() - 0.5) * 30) + 'px';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2000);
          }, i * 200);
        }
        break;
      case 'centurion':
        // Gold confetti — use main confetti but with gold colors
        startConfetti();
        setTimeout(startConfetti, 300);
        break;
      case 'streakMaster':
        for (let i = 0; i < 12; i++) {
          setTimeout(() => {
            const el = document.createElement('div');
            el.className = 'mood-particle star';
            el.textContent = '⭐';
            el.style.left = (cx + (Math.random() - 0.5) * 80) + 'px';
            el.style.top = (cy + (Math.random() - 0.5) * 50) + 'px';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2500);
          }, i * 100);
        }
        break;
      case 'resurrector':
        for (let i = 0; i < 6; i++) {
          setTimeout(() => {
            const el = document.createElement('div');
            el.className = 'mood-particle heart';
            el.textContent = '😭';
            el.style.fontSize = '18px';
            el.style.left = (cx + (Math.random() - 0.5) * 40) + 'px';
            el.style.top = (cy + (Math.random() - 0.5) * 30) + 'px';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2000);
          }, i * 200);
        }
        break;
      case 'marathon':
        startConfetti();
        for (let i = 0; i < 3; i++) {
          setTimeout(() => {
            const el = document.createElement('div');
            el.className = 'mood-particle sparkle';
            el.textContent = '🏅';
            el.style.fontSize = '22px';
            el.style.left = (cx + (Math.random() - 0.5) * 40) + 'px';
            el.style.top = (cy - 10) + 'px';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2500);
          }, i * 400);
        }
        break;
    }
  }

  // --- Double-click → pet, Long press → stats HUD ---
  let pressTimer = null;
  let lastClickTime = 0;
  document.querySelector('.mascot-wrap').addEventListener('mousedown', () => {
    pressTimer = setTimeout(() => {
      // Long press: show mini stats HUD
      pressTimer = null;
      showStatsHUD();
    }, 1000);
  });
  document.querySelector('.mascot-wrap').addEventListener('mouseup', () => {
    if (pressTimer) {
      clearTimeout(pressTimer);
      const now = Date.now();
      if (now - lastClickTime < 350) {
        // Double click: pet animation
        petAnimation();
      }
      lastClickTime = now;
    }
  });
  document.querySelector('.mascot-wrap').addEventListener('mouseleave', () => {
    if (pressTimer) clearTimeout(pressTimer);
  });

  function petAnimation() {
    mascot.classList.add('jiggle');
    // Spawn hearts
    const rect = mascot.getBoundingClientRect();
    for (let i = 0; i < 3; i++) {
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'mood-particle heart';
        el.textContent = '💚';
        el.style.left = (rect.left + rect.width / 2 + (Math.random() - 0.5) * 30) + 'px';
        el.style.top = (rect.top + (Math.random() - 0.5) * 20) + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1500);
      }, i * 150);
    }
    setTimeout(() => mascot.classList.remove('jiggle'), 300);
  }

  function showStatsHUD() {
    // Read stats from batch data if available
    const existing = document.querySelector('.stats-hud');
    if (existing) { existing.remove(); return; }
    const hud = document.createElement('div');
    hud.className = 'stats-hud';
    hud.style.cssText = 'position:fixed;bottom:70px;right:12px;background:rgba(0,0,0,0.85);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:8px 12px;font-family:SF Mono,Menlo,monospace;font-size:11px;color:#e2e8f0;z-index:20;backdrop-filter:blur(8px);';
    hud.innerHTML = '<div style="color:' + getMoodConfig().color + ';font-weight:bold;margin-bottom:4px;">' + currentMood + '</div><div style="opacity:0.6;font-size:10px;">Double-click to pet</div>';
    document.body.appendChild(hud);
    setTimeout(() => { if (hud.parentNode) hud.remove(); }, 3000);
  }

  // --- Setup message for a single cycle ---
  function setupMessage(m) {
    // Set current mood from message
    currentMood = m.mood || 'NEUTRAL';
    const mc = getMoodConfig();

    // Update mascot filter for mood
    mascot.style.filter = mc.filter || '';

    msgEl.innerHTML = '';
    msgEl.className = 'message';
    const words = m.msg.split(/(\s+)/);
    const wordSpans = [];
    for (const w of words) {
      const span = document.createElement('span');
      if (w.trim()) {
        span.className = 'word';
        wordSpans.push(span);
      }
      span.textContent = w;
      msgEl.appendChild(span);
    }
    if (m.mode === 'permission') {
      msgEl.classList.add('permission');
      msgEl.style.setProperty('--lit-color', '#facc15');
    } else {
      // Use mood color for lit words
      msgEl.style.setProperty('--lit-color', mc.color);
    }
    return wordSpans;
  }

  // --- Batch runner ---
  async function runBatch(messages) {
    // ENTRANCE (once)
    // t=0: mascot bouncySlideIn (600ms) — already playing via CSS
    await delay(600);
    mascot.classList.add('jiggle');
    await delay(50);
    mascot.classList.remove('jiggle');
    // Kill base bouncySlideIn, start persistent breathing
    mascot.style.animation = 'none';
    mascot.style.opacity = '1';
    mascot.style.transform = 'translateX(0)';
    startBreathing();

    // PER MESSAGE loop
    for (let i = 0; i < messages.length; i++) {
      const m = messages[i];
      const wordSpans = setupMessage(m);

      // Show bubble
      bubble.className = 'bubble show';
      if (m.mode === 'permission') bubble.classList.add('permission-pulse');

      // Start voice reactivity (overrides breathing while active)
      const estDur = m.voiceDur || 3000;
      startVoiceReactivity(estDur);
      const step = wordSpans.length > 1 ? estDur / (wordSpans.length - 1) : 0;
      wordSpans.forEach((span, j) => {
        setTimeout(() => {
          span.classList.add('lit');
          span.style.transform = 'scale(1.08)';
          setTimeout(() => { span.style.transform = 'scale(1)'; }, 150);
        }, j * step);
      });

      // Mood particles
      startMoodParticles();

      // Mode effects — mood-aware
      const mc = getMoodConfig();
      if (m.mode === 'done') {
        if (currentMood === 'ECSTATIC') { startConfetti(); setTimeout(startConfetti, 300); }
        else if (mc.particles === 'confetti' || currentMood === 'HAPPY') startConfetti();
        // Other moods: skip confetti, mood particles suffice
      }
      if (m.mode === 'permission') spawnOrbitingMarks();

      // Achievement celebration
      if (m.achievement) celebrateAchievement(m.achievement);

      // Sleeping: no speech bubble, just ZZZ
      if (currentMood === 'SLEEPING') {
        bubble.className = 'bubble';
        stopMoodParticles();
        startMoodParticles();
        await delay(m.duration + 1000);
        stopMoodParticles();
        if (i < messages.length - 1) await delay(150);
        continue;
      }

      // Play audio — blocks until both lines finish
      await playVoiceLines(m);
      await delay(100);

      // Voice done — breathing loop resumes automatically
      voiceActive = false;

      // Display duration (breathing continues)
      await delay(m.duration + 1000);

      // Hide bubble (breathing continues)
      bubble.className = 'bubble hide';
      stopMoodParticles();
      await delay(250);

      // Gap before next message (breathing continues)
      if (i < messages.length - 1) await delay(150);
    }

    // EXIT (once) — stop breathing, vacuum + spin out
    stopBreathing();
    startVacuum();
    await delay(400);
    mascot.style.animation = 'spinOut 0.8s ease-in forwards';
    const shadow = document.querySelector('.mascot-shadow');
    if (shadow) shadow.style.animation = 'shadowShrink 0.8s ease-in forwards';
    await delay(900);
    document.title = 'CLOSE';
  }

  // --- Click to activate terminal ---
  document.querySelector('.bubble').addEventListener('click', (e) => {
    e.stopPropagation();
    document.title = 'ACTIVATE';
  });

  // --- Load batch and run ---
  fetch('file:///tmp/toast-batch.json')
    .then(r => r.json())
    .then(data => runBatch(data.messages))
    .catch(() => {
      // Fallback: single default message
      runBatch([{ msg: 'Hello', mode: 'done', duration: 3000, voiceDur: 3000 }]);
    });
</script>
</body>
</html>
