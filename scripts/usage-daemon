#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# Claude Usage Daemon
#
# Runs usage-scraper every 2 minutes in the background.
# Sends a Telegram notification when a full session becomes
# available again (session drops from >=100% to <100%),
# provided the weekly limit isn't exhausted.
#
# Usage:
#   ./scripts/usage-daemon          # Start daemon (foreground)
#   ./scripts/usage-daemon --stop   # Stop running daemon
#   ./scripts/usage-daemon --status # Check if running
# ──────────────────────────────────────────────────────────────
set -euo pipefail

CONTEXT_DIR="${HOME}/.config/claude-mascot"
USAGE_FILE="${CONTEXT_DIR}/usage.json"
PID_FILE="${CONTEXT_DIR}/.usage-daemon.pid"
SESSION_FULL_MARKER="${CONTEXT_DIR}/.session-was-full"
POLL_INTERVAL=120  # seconds

# Resolve repo root (directory containing this script's parent)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SCRAPER="${SCRIPT_DIR}/usage-scraper"

mkdir -p "$CONTEXT_DIR"

# ── CLI: --stop ────────────────────────────────────────────────
if [ "${1:-}" = "--stop" ]; then
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            echo "Stopped usage-daemon (PID $pid)"
        else
            echo "PID $pid not running (stale PID file)"
        fi
        rm -f "$PID_FILE"
    else
        echo "No PID file found — daemon not running"
    fi
    exit 0
fi

# ── CLI: --status ──────────────────────────────────────────────
if [ "${1:-}" = "--status" ]; then
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "Running (PID $pid)"
            exit 0
        else
            echo "Not running (stale PID file)"
            rm -f "$PID_FILE"
            exit 1
        fi
    else
        echo "Not running"
        exit 1
    fi
fi

# ── Guard: already running? ───────────────────────────────────
if [ -f "$PID_FILE" ]; then
    existing_pid=$(cat "$PID_FILE")
    if kill -0 "$existing_pid" 2>/dev/null; then
        echo "Daemon already running (PID $existing_pid)"
        exit 1
    fi
    rm -f "$PID_FILE"
fi

# ── Load Telegram config ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_ENABLED="false"

if [ -f "$REPO_ROOT/.env" ]; then
    # Simple key=value parser (no eval for safety)
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        # Strip surrounding quotes
        value="${value%\"}"
        value="${value#\"}"
        value="${value%\'}"
        value="${value#\'}"
        case "$key" in
            TELEGRAM_BOT_TOKEN)  TELEGRAM_BOT_TOKEN="$value" ;;
            TELEGRAM_CHAT_ID)    TELEGRAM_CHAT_ID="$value" ;;
            TELEGRAM_ENABLED)    TELEGRAM_ENABLED="$value" ;;
        esac
    done < "$REPO_ROOT/.env"
fi

# ── Telegram notification ─────────────────────────────────────
send_telegram() {
    local message="$1"
    if [ "$TELEGRAM_ENABLED" != "true" ] || [ -z "$TELEGRAM_BOT_TOKEN" ] || [ -z "$TELEGRAM_CHAT_ID" ]; then
        return 0
    fi
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
        -d chat_id="$TELEGRAM_CHAT_ID" \
        -d text="$message" \
        -d parse_mode="Markdown" \
        >/dev/null 2>&1 || true
}

# ── Parse usage.json with perl (no jq) ────────────────────────
read_usage_field() {
    local field="$1"
    [ -f "$USAGE_FILE" ] || return 1
    perl -e '
        use strict;
        my $field = $ARGV[0];
        my $text = do { local $/; open my $fh, "<", $ARGV[1] or exit 1; <$fh> };
        if ($text =~ /"$field"\s*:\s*(\d+)/) {
            print $1;
        } else {
            exit 1;
        }
    ' "$field" "$USAGE_FILE"
}

# ── Graceful shutdown ──────────────────────────────────────────
cleanup() {
    rm -f "$PID_FILE"
    exit 0
}
trap cleanup SIGTERM SIGINT

# ── Write PID and start loop ──────────────────────────────────
echo $$ > "$PID_FILE"
echo "Usage daemon started (PID $$, polling every ${POLL_INTERVAL}s)"

# Seed the marker state from current usage if available
session_pct=$(read_usage_field "session_pct" 2>/dev/null || echo "")
if [ -n "$session_pct" ] && [ "$session_pct" -ge 100 ] 2>/dev/null; then
    touch "$SESSION_FULL_MARKER"
fi

while true; do
    # Run scraper (ignore failures — it has its own retry logic)
    "$SCRAPER" 2>/dev/null || true

    # Check for session transition
    session_pct=$(read_usage_field "session_pct" 2>/dev/null || echo "")
    week_all_pct=$(read_usage_field "week_all_pct" 2>/dev/null || echo "")

    if [ -n "$session_pct" ]; then
        if [ "$session_pct" -ge 100 ] 2>/dev/null; then
            # Session is full — mark it
            touch "$SESSION_FULL_MARKER"
        elif [ -f "$SESSION_FULL_MARKER" ]; then
            # Session was full, now available — notify!
            rm -f "$SESSION_FULL_MARKER"

            # Only notify if weekly limit isn't exhausted
            if [ -n "$week_all_pct" ] && [ "$week_all_pct" -lt 100 ] 2>/dev/null; then
                send_telegram "🟢 *Session available* — usage dropped to ${session_pct}% (week: ${week_all_pct}%)"
            fi
        fi
    fi

    sleep "$POLL_INTERVAL" &
    wait $!
done
