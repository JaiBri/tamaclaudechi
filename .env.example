# ──────────────────────────────────────────────────────────────
# Telegram Notifications for Claude Usage Daemon
#
# Setup:
#   1. Open Telegram, search for @BotFather, start a chat
#   2. Send /newbot, follow prompts, copy the bot token
#   3. Start a chat with your new bot (search its @username)
#   4. Send it any message (e.g. "hello")
#   5. Get your chat ID:
#      curl -s "https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates" | python3 -m json.tool
#      → look for "chat": { "id": 123456789 }
#   6. Copy this file to .env and fill in the values:
#      cp .env.example .env
#   7. Test:
#      source .env && curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
#        -d chat_id="${TELEGRAM_CHAT_ID}" -d text="Test from usage-daemon"
# ──────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_ENABLED="true"
